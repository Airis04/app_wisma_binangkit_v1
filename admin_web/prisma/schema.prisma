// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id_user      String   @id @db.Char(10)
  nama_lengkap String   @db.VarChar(30)
  email        String   @unique @db.VarChar(30)
  password     String   @db.VarChar(100)
  no_telepon   String   @db.VarChar(15)
  role         String   @db.VarChar(10)
  created_at   DateTime @default(now())

  reservations Reservation[]
}

model Unit {
  id_unit         String   @id @db.Char(10)
  nama_unit       String   @db.VarChar(30)
  kategori        String   @db.VarChar(30)
  harga_per_malam Int
  kapasitas       Int
  fasilitas       String   @db.Text
  foto_unit       String?  @db.VarChar(255)
  status_unit     String   @default("Tersedia") @db.VarChar(20)

  reservations Reservation[]
}

model Reservation {
  id_reservasi   String   @id @db.Char(10)
  id_user        String   @db.Char(10)
  id_unit        String   @db.Char(10)
  tgl_checkin    DateTime
  tgl_checkout   DateTime
  total_tagihan  Int
  bukti_bayar    String?  @db.VarChar(255)
  status_pesanan String   @db.VarChar(25)
  created_at     DateTime @default(now())

  // Relasi
  user User @relation(fields: [id_user], references: [id_user])
  unit Unit @relation(fields: [id_unit], references: [id_unit])

  // Wajib menambahkan index pada rentang tanggal untuk kecepatan Overlap Detection sesuai PRD
  @@index([tgl_checkin, tgl_checkout])
}

model OperationalCost {
  id_biaya              String   @id @db.Char(10)
  tanggal_pencatatan    DateTime
  kategori_pengeluaran  String   @db.VarChar(50)
  deskripsi_pengeluaran String   @db.VarChar(100)
  total_pengeluaran     Int
}